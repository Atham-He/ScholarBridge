# ============= ScholarBridge 统一配置文件 =============
# 所有服务（backend + supervisor_born）都从根目录读取此配置

# ============= 服务端口配置 =============
BACKEND_PORT=3001
SUPERVISOR_PORT=3002

# ============= 数据库配置 =============
DATABASE_URL="file:./backend/dev.db"
SESSION_SECRET="scholarbridge-secret-key-2024-super-secure-random-string-for-development"

# ============= LLM 提供商配置 =============
# 统一的 LLM 配置，适用于所有服务

# 选择 LLM 提供商: mock | openai | anthropic | deepseek
LLM_PROVIDER="openai"

# OpenAI 配置（推荐，支持视觉功能）
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_SUPPORTS_VISION=true

# Anthropic Claude 配置
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-haiku-latest"

# DeepSeek 配置（性价比高）
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"

# ============= 搜索服务配置 =============
# 网页搜索提供商: multi | bing | google | duckduckgo
WEB_SEARCH_PROVIDER="multi"

# Bing 搜索 API
BING_SEARCH_API_KEY=""
BING_SEARCH_ENDPOINT="https://api.bing.microsoft.com/v7.0/search"

# Google 搜索 API
GOOGLE_SEARCH_API_KEY=""
GOOGLE_SEARCH_CX=""

# OpenAlex 学术数据库（免费，无需 API Key）
OPENALEX_EMAIL="noreply@scholarbridge.edu"

# ============= 文件上传配置 =============
MAX_UPLOAD_SIZE_MB="10"
ALLOWED_UPLOAD_TYPES="pdf,docx,doc,txt,md,png,jpg,jpeg,gif,webp"

# ============= Persona 配置 =============
MAX_PUBLIC_PAGES=6
MAX_PAPERS=8
FETCH_TIMEOUT_MS=15000

# ============= 开发环境配置 =============
NODE_ENV="development"
LOG_LEVEL="info"  # debug | info | warn | error
DATA_DIR="./supervisor_born/data"

# ============= 使用说明 =============
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填写你的 API 密钥（至少配置一个 LLM 提供商）
# 3. 运行: npm run dev:all
#
# 注意事项：
# - 开发测试可使用 LLM_PROVIDER="mock"（无需 API Key）
# - 生产环境建议使用 openai 或 anthropic
# - DuckDuckGo 搜索始终可用（无需 API Key）
# - OpenAlex 是免费的学术数据库（推荐使用）
