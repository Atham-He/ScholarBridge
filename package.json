{
  "name": "scholarbridge",
  "version": "1.0.0",
  "description": "AI-powered mentor-student matching platform",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cd backend && npm run dev",
    "dev:all": "cd backend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "build": "cd backend && npm run build",
    "start": "cd backend && npm run start",
    "start:all": "cd backend && npm run start",
    "start:backend": "cd backend && npm run start",
    "lint": "cd backend && npm run lint",
    "db:generate": "cd backend && prisma generate",
    "db:migrate": "cd backend && prisma migrate dev",
    "db:seed": "cd backend && prisma db seed",
    "db:import-supervisor-mentors": "cd backend && node scripts/import-symbolicvideo-mentors.mjs",
    "db:push": "cd backend && prisma db push",
    "db:studio": "cd backend && prisma studio",
    "pre-migration": "tsx scripts/pre-migration-check.ts",
    "persona:smoke": "cd backend && npm run persona:smoke",
    "persona:real-e2e": "cd backend && npm run persona:real-e2e",
    "test": "cd backend && npm test",
    "test:watch": "cd backend && npm run test:watch",
    "type-check": "cd backend && npm run type-check"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.2",
    "cheerio": "^1.0.0",
    "dotenv": "^16.6.1",
    "iron-session": "^8.0.4",
    "mammoth": "^1.8.0",
    "next": "16.2.2",
    "openai": "^4.0.0",
    "pdf-parse": "^1.1.1",
    "prisma": "^6.19.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "word-extractor": "^0.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jest": "^29.5.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
