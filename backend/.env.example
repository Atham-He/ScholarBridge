# Database
DATABASE_URL="file:./dev.db"

# Session
SESSION_SECRET="replace-with-at-least-32-characters-long-secret"

# ============= Persona LLM Configuration =============

# LLM Provider Selection
PERSONA_LLM_PROVIDER="mock"  # mock|anthropic|openai|deepseek

# Anthropic Claude (recommended, supports vision)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-haiku-latest"

# OpenAI GPT (also supports some vision capabilities)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# DeepSeek (cost-effective alternative)
DEEPSEEK_API_KEY=""

# ============= Public Search Configuration =============

# Web Search Providers
# At least one provider is recommended for automatic public information gathering
# Leave all empty to use DuckDuckGo (free, no API key, limited results)

# Bing Search API
BING_SEARCH_API_KEY=""
# Get from: https://www.microsoft.com/en-us/bing/apis/bing-web-search-api
# Free tier: 1000 queries/month

# Google Custom Search API
GOOGLE_SEARCH_API_KEY=""
GOOGLE_SEARCH_CX=""
# Get from: https://developers.google.com/custom-search/v1/overview
# Create Custom Search Engine at: https://cse.google.com/cse/
# Free tier: 100 queries/day

# OpenAlex Academic Database (FREE, no API key required!)
# OpenAlex is a fully open catalog of the global research system
# Setting an email allows access to the Polite Pool (better rate limits)
OPENALEX_EMAIL="noreply@scholarbridge.edu"
# Get more info: https://openalex.org/

# ============= File Upload Configuration =============

# File Upload Limits
MAX_UPLOAD_SIZE_MB="10"
ALLOWED_UPLOAD_TYPES="pdf,docx,doc,txt,md,png,jpg,jpeg,gif,webp"

# Upload Directory (optional, defaults to ./uploads)
# UPLOAD_DIR="./uploads"

# Optional: required only for parsing dynamic ChatGPT share URLs
# If omitted, ScholarBridge will try common Chrome / Chromium install paths.
# CHROME_PATH="C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe"

# ============= Development Settings =============

# Environment
NODE_ENV="development"

# Log Level
LOG_LEVEL="info"  # debug|info|warn|error

# ============= Notes =============

# 1. For development, PERSONA_LLM_PROVIDER="mock" works without any API keys
# 2. For production, use anthropic or openai for best results
# 3. DuckDuckGo search is always available (no API key needed)
# 4. OpenAlex is free and recommended for academic sources
# 5. File upload works with any LLM provider
# 6. ChatGPT share URL ingestion needs a local Chrome / Chromium executable
