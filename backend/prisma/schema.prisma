generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  OPEN
  CLOSED
  COMPLETED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  orcidId      String?   @unique
  orcidEmail   String?
  orcidName    String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  emailVerified         Boolean @default(false)
  emailVerificationCode String?

  profile Profile?

  ownedProjects         Project[]           @relation("OwnedProjects")
  savedProjects         SavedProject[]
  applicationsSubmitted Application[]       @relation("ApplicationsSubmitted")
  applicationsReceived  Application[]       @relation("ApplicationsReceived")
  notifications         Notification[]
  emailVerifications    EmailVerification[]
  securityEvents        SecurityEvent[]

  @@index([orcidId])
  @@index([email])
}

model Profile {
  userId          String  @id
  displayName     String
  institution     String?
  department      String?
  title           String?
  education       String?
  bioShort        String?
  backgroundBrief String?
  location        String?
  contactEmail    String?
  phone           String?
  website         String?
  researchAreas   Json?
  interests       Json?
  skills          Json?
  materialsJson   Json?
  status          String  @default("active")

  resumeFileName   String?
  resumeMimeType   String?
  resumeSize       Int?
  resumeData       Bytes?
  resumeText       String?
  resumeUploadedAt DateTime?

  aiAgentEnabled Boolean @default(true)
  aiAgentPrompt  String?
  aiHardWeight   Int     @default(50)
  aiFitWeight    Int     @default(50)

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedProject {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
}

model Project {
  id              String        @id @default(cuid())
  ownerUserId     String
  title           String
  description     String
  researchArea    String
  startTime       String
  endTime         String?
  location        String?
  requirements    String?
  illustrationUrl String?
  capacity        Int
  enrolled        Int           @default(0)
  status          ProjectStatus @default(OPEN)

  owner        User           @relation("OwnedProjects", fields: [ownerUserId], references: [id], onDelete: Cascade)
  applications Application[]
  savedBy      SavedProject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerUserId])
  @@index([status])
}

model Application {
  id              String    @id @default(cuid())
  applicantUserId String
  ownerUserId     String
  projectId       String
  status          String    @default("pending")
  coverLetter     String?
  ownerFeedback   String?
  aiHardScore     Float?
  aiFitScore      Float?
  aiScoreSummary  String?
  aiScoreError    String?
  aiScoredAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  applicant User    @relation("ApplicationsSubmitted", fields: [applicantUserId], references: [id], onDelete: Cascade)
  owner     User    @relation("ApplicationsReceived", fields: [ownerUserId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([applicantUserId, projectId])
  @@index([ownerUserId])
  @@index([applicantUserId])
  @@index([projectId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerification {
  id            String    @id @default(cuid())
  email         String
  code          String
  expiresAt     DateTime
  verified      Boolean   @default(false)
  usedAt        DateTime?
  attemptCount  Int       @default(0)
  lastAttemptAt DateTime?
  ipAddress     String?
  createdAt     DateTime  @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  @@index([email])
  @@index([expiresAt])
  @@index([code])
}

model ORCIDAccount {
  id             String    @id @default(cuid())
  orcidId        String    @unique
  name           String
  email          String
  avatarUrl      String?
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model SecurityEvent {
  id        String   @id @default(cuid())
  userId    String?
  eventType String
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}
