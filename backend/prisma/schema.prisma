generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MENTOR
  STUDENT
}

enum ProjectStatus {
  OPEN
  CLOSED
  COMPLETED
}

model User {
  id           String   @id @default(cuid())
  email        String
  passwordHash String?
  role         UserRole
  orcidId      String?  @unique
  orcidEmail   String?
  orcidName    String?
  lastLoginAt  DateTime?
  lastRoleAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  emailVerified         Boolean   @default(false)
  emailVerificationCode String?

  mentorProfile  MentorProfile?
  studentProfile StudentProfile?

  applicationsAsStudent Application[] @relation("StudentApps")
  applicationsAsMentor  Application[] @relation("MentorApps")

  notifications Notification[]
  emailVerifications EmailVerification[]
  securityEvents   SecurityEvent[]

  @@unique([email, role])
  @@index([orcidId])
  @@index([email])
}

model MentorProfile {
  userId          String  @id
  displayName     String
  institution     String
  department      String?
  title           String?
  bioShort        String?
  location        String?
  contactEmail    String?
  phone           String?
  website         String?
  researchAreas   Json?   // ["AI", "Machine Learning", "Robotics"]
  status          String  @default("active") // active, inactive
  updatedAt       DateTime @updatedAt

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]
}

model StudentProfile {
  userId        String @id
  displayName   String
  backgroundBrief String?
  materialsJson   Json?
  education       String?
  bioShort        String?
  interests       Json?
  skills          Json?

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedMentors  SavedMentor[]
}

model SavedMentor {
  id        String   @id @default(cuid())
  studentUserId String
  mentorUserId  String
  createdAt DateTime @default(now())

  student StudentProfile @relation(fields: [studentUserId], references: [userId], onDelete: Cascade)

  @@unique([studentUserId, mentorUserId])
  @@index([studentUserId])
}

model Project {
  id           String   @id @default(cuid())
  mentorUserId String
  title        String
  description  String
  researchArea String
  startTime    String   // "2025-09"
  endTime      String?  // "2028-09" or null for ongoing
  location     String?  // "On-site" or "Remote" or specific location
  requirements String?  // Project requirements
  capacity     Int      // Total positions
  enrolled     Int      @default(0) // Currently enrolled
  status       ProjectStatus @default(OPEN)

  mentor       MentorProfile  @relation(fields: [mentorUserId], references: [userId], onDelete: Cascade)
  applications Application[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([mentorUserId])
  @@index([status])
}

model Application {
  id            String          @id @default(cuid())
  studentUserId String
  mentorUserId  String
  projectId     String
  status        String          @default("pending") // pending, accepted, rejected, withdrawn
  coverLetter   String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  student User            @relation("StudentApps", fields: [studentUserId], references: [id], onDelete: Cascade)
  mentor  User            @relation("MentorApps", fields: [mentorUserId], references: [id], onDelete: Cascade)
  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([studentUserId, projectId])
  @@index([mentorUserId])
  @@index([studentUserId])
  @@index([projectId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerification {
  id           String   @id @default(cuid())
  email        String
  code         String
  role         UserRole
  expiresAt    DateTime
  verified     Boolean  @default(false)
  usedAt       DateTime?
  attemptCount Int      @default(0)
  lastAttemptAt DateTime?
  ipAddress    String?
  createdAt    DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  @@index([email])
  @@index([expiresAt])
  @@index([code])
}

model ORCIDAccount {
  id             String   @id @default(cuid())
  orcidId        String   @unique
  name           String
  email          String
  avatarUrl      String?
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model SecurityEvent {
  id        String   @id @default(cuid())
  userId    String?
  eventType String
  ipAddress String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
}
